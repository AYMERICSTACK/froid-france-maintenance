generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  TECHNICIAN
  USER
}

enum ContractStatus {
  ACTIVE
  INACTIVE
  EXPIRED
}

enum InterventionStatus {
  TO_PLAN
  PLANNED
  DONE
  CANCELLED
}

enum ReminderStatus {
  PENDING
  SENT
  FAILED
}

enum DocumentCategory {
  GENERAL
  BEFORE_PHOTO
  AFTER_PHOTO
  REPORT
}

enum EmailLogStatus {
  SENT
  FAILED
}

model User {
  id            String         @id @default(cuid())
  firstName     String
  lastName      String
  email         String         @unique
  passwordHash  String
  role          UserRole       @default(USER)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  interventions Intervention[]
  emailLogs     EmailLog[]
}

model Client {
  id         String     @id @default(cuid())
  firstName  String
  lastName   String
  phone      String?
  email      String?
  address    String?
  city       String?
  postalCode String?
  notes      String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  contracts  Contract[]
  documents  Document[]
}

model Contract {
  id                  String          @id @default(cuid())
  clientId            String
  equipmentType       String
  brand               String?
  model               String?
  subscriptionDate    DateTime?
  lastMaintenanceDate DateTime?
  nextMaintenanceDate DateTime
  frequencyMonths     Int             @default(12)
  status              ContractStatus  @default(ACTIVE)
  notes               String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  client         Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  interventions  Intervention[]
  reminders      Reminder[]
  documents      Document[]
  emailLogs      EmailLog[]
}

model Intervention {
  id          String             @id @default(cuid())
  contractId  String
  userId      String?
  plannedDate DateTime?
  doneDate    DateTime?
  status      InterventionStatus @default(TO_PLAN)
  notes       String?
  confirmationSentAt DateTime?
  reportGeneratedAt  DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  user     User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  documents Document[]
  emailLogs EmailLog[]
}

model Reminder {
  id             String         @id @default(cuid())
  contractId     String
  type           String
  scheduledFor   DateTime
  sentAt         DateTime?
  recipientEmail String
  status         ReminderStatus @default(PENDING)
  errorMessage   String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
}

model Document {
  id         String    @id @default(cuid())
  name       String
  fileUrl    String
  mimeType   String?
  size       Int?
  clientId   String?
  contractId String?
  interventionId String?
  storagePath String?
  category   DocumentCategory @default(GENERAL)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  client     Client?   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  contract   Contract? @relation(fields: [contractId], references: [id], onDelete: Cascade)
  intervention Intervention? @relation(fields: [interventionId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([contractId])
  @@index([interventionId])
}


model EmailLog {
  id             String         @id @default(cuid())
  type           String
  recipientEmail String
  subject        String
  status         EmailLogStatus @default(SENT)
  errorMessage   String?
  sentAt         DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  contractId     String?
  interventionId String?
  userId         String?

  contract       Contract?      @relation(fields: [contractId], references: [id], onDelete: Cascade)
  intervention   Intervention?  @relation(fields: [interventionId], references: [id], onDelete: Cascade)
  user           User?          @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([contractId])
  @@index([interventionId])
  @@index([userId])
  @@index([type])
}


model AutomationRun {
  id           String   @id @default(cuid())
  type         String
  source       String
  status       String
  foundCount   Int      @default(0)
  sentCount    Int      @default(0)
  skippedCount Int      @default(0)
  failedCount  Int      @default(0)
  message      String?
  startedAt    DateTime @default(now())
  endedAt      DateTime?
  createdAt    DateTime @default(now())

  @@index([type])
  @@index([createdAt])
}
